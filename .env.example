# Copy to .env.local and fill in what you're actually testing.
# Every integration degrades gracefully without its key — the site runs
# and demos fine with an empty .env.local. .env.local is gitignored.

# AI concierge (app/[locale]/assistant)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GROQ_API_KEY=
GROQ_MODEL=
GOOGLE_GENAI_API_KEY=

# Error monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=            # optional — only needed for source-map upload
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Shopify commerce — see lib/shopify-client.ts for how these are used
SHOPIFY_STORE_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# Google Analytics 4 (admin analytics dashboard)
NEXT_PUBLIC_GA4_ID=
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_EMAIL=
GA4_SERVICE_ACCOUNT_PRIVATE_KEY=

# Redis (Upstash) — rate limiting, trade-lead storage, caching
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin panel — no user database, checked directly against these
ADMIN_EMAIL=
ADMIN_PASSWORD=
SESSION_SECRET=

# Email (Resend) — trade-lead notifications and the daily digest
RESEND_API_KEY=
TRADE_LEAD_NOTIFY_EMAIL=
TRADE_LEAD_NOTIFY_FROM=
DIGEST_NOTIFY_EMAIL=

# Daily digest cron endpoint — required to authorize the scheduled trigger
CRON_SECRET=

# Site config
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_TRADE_SCHEDULING_URL=
